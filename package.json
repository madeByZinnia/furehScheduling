{
  "name": "fureh-schedules",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Fur-Eh 2026 crew schedule — Telegram Mini App + web (Cloudflare Worker)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "schedule": "tsx scripts/fetch-schedule.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.19",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@preact/preset-vite": "^2.10.1",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.23.2",
    "globals": "^15.14.0",
    "happy-dom": "^16.7.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.11",
    "vitest": "^3.0.5",
    "wrangler": "^3.107.0"
  }
}
